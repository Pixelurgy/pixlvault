# Optional environment overrides for the Docker container.
#
# By default everything (config, images, downloaded models) is stored inside
# the 'pixlvault-home' named Docker volume, using the same layout as a regular
# Linux install:
#
#   ~/.config/pixlvault/server-config.json
#   ~/.config/pixlvault/images/    ← images + vault.db
#   ~/.local/share/pixlvault/downloaded_models/
#
# To store images on your real filesystem instead, set PIXLVAULT_IMAGE_ROOT
# to an absolute path inside the container AND add a matching bind mount in
# docker-compose.yml under the volumes section, e.g.:
#
#   volumes:
#     - pixlvault-home:/home/pixlvault
#     - /home/yourname/photos:/mnt/photos   ← add this
#   environment:
#     PIXLVAULT_IMAGE_ROOT: /mnt/photos     ← and this

# PIXLVAULT_IMAGE_ROOT=/mnt/photos
