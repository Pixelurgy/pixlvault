# Optional environment overrides for the Docker container.
#
# By default everything (config, images, downloaded models) is stored inside
# the 'pixlstash-home' named Docker volume, using the same layout as a regular
# Linux install:
#
#   ~/.config/pixlstash/server-config.json
#   ~/.config/pixlstash/images/    ← images + vault.db
#   ~/.local/share/pixlstash/downloaded_models/
#
# To store images on your real filesystem instead, set PIXLSTASH_IMAGE_ROOT
# to an absolute path inside the container AND add a matching bind mount in
# docker-compose.yml under the volumes section, e.g.:
#
#   volumes:
#     - pixlstash-home:/home/pixlstash
#     - /home/yourname/photos:/mnt/photos   ← add this
#   environment:
#     PIXLSTASH_IMAGE_ROOT: /mnt/photos     ← and this

# PIXLSTASH_IMAGE_ROOT=/mnt/photos
